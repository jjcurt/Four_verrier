# =============================================================================
# Ajouts au .gitignore existant pour le projet Four_verrier
# Copier-coller ces lignes dans votre .gitignore à la racine du projet
# =============================================================================

# Fichier de secrets — NE JAMAIS COMMITER
include/secrets.h

# Binaires de compilation PlatformIO (si pas déjà présents)
.pio/
.vscode/

# PlatformIO build artifacts
#.pio
#.vscode/.browse.c_cpp.db*
#.vscode/c_cpp_properties.json
#.vscode/launch.json
#.vscode/ipch

# Binaires compilés et firmwares
*.bin
*.elf
*.hex
# binaires/ est un lien symbolique vers .pio/build/ pour accès web
# NE PAS supprimer (nécessaire car interface web ne montre pas dossiers cachés)
binaires/
firmware_*.bin

# Python
.venv/
__pycache__/
*.pyc
venv/
env/

# Données sensibles (SD card)
data/config/wifi.json
data/logs/*.csv
data/logs/

# IDE et éditeurs
# .code-workspace est à la racine (pas dans include/)
*.code-workspace
.idea/
*.swp
*.swo
*~

# Temporaires
*.tmp
*.bak
*.old

# OS
.DS_Store
Thumbs.db
